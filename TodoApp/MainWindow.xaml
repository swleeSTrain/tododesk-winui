<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="TodoApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TodoApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="TodoDesk"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootLayout" Background="{ThemeResource LiquidGlassWindowBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.RowSpan="2"
            Background="{ThemeResource LiquidGlassRegularWashBrush}"
            IsHitTestVisible="False" />

        <Grid x:Name="CustomTitleBarHost" Height="44">
            <Border
                Background="{ThemeResource LiquidGlassRegularWashBrush}"
                Opacity="0.16" />
            <Border
                Background="{ThemeResource LiquidGlassContentInfusionBrush}"
                IsHitTestVisible="False"
                Opacity="0.055">
                <Border.RenderTransform>
                    <CompositeTransform ScaleX="1.18" SkewX="-8" />
                </Border.RenderTransform>
            </Border>
            <Border
                Background="{ThemeResource LiquidGlassSpecularBrush}"
                IsHitTestVisible="False"
                Opacity="0.040" />
            <Border
                Height="10"
                Margin="72,3,190,0"
                VerticalAlignment="Top"
                Background="{ThemeResource LiquidGlassSpecularBrush}"
                CornerRadius="5"
                IsHitTestVisible="False"
                Opacity="0.055" />
            <Border
                Height="14"
                Margin="360,1,280,0"
                VerticalAlignment="Center"
                Background="{ThemeResource LiquidGlassCausticBrush}"
                CornerRadius="7"
                IsHitTestVisible="False"
                Opacity="0.026" />
            <Border
                Height="1"
                VerticalAlignment="Bottom"
                Background="{ThemeResource LiquidGlassEdgeGlowBrush}"
                IsHitTestVisible="False"
                Opacity="0.16" />
            <Border
                Height="1"
                Margin="0,0,0,1"
                VerticalAlignment="Bottom"
                Background="{ThemeResource LiquidGlassShadowStrokeBrush}"
                IsHitTestVisible="False"
                Opacity="0.08" />
            <Grid
                x:Name="AppTitleBar"
                Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="150" />
                </Grid.ColumnDefinitions>
                <Border
                    Grid.Column="2"
                    Margin="4,6,10,6"
                    Background="{ThemeResource LiquidGlassToolbarBrush}"
                    BorderBrush="{ThemeResource LiquidGlassRimBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Loaded="BackdropDistortion_Loaded"
                    Tag="TitleCapsule"
                    Unloaded="BackdropDistortion_Unloaded"
                    IsHitTestVisible="False">
                    <Grid>
                        <Border
                            Background="{ThemeResource LiquidGlassRefractionBrush}"
                            CornerRadius="15"
                            IsHitTestVisible="False"
                            Opacity="0.18" />
                        <Border
                            Background="{ThemeResource LiquidGlassSpecularBrush}"
                            CornerRadius="15"
                            IsHitTestVisible="False"
                            Opacity="0.20" />
                        <Border
                            Height="10"
                            Margin="14,2,14,0"
                            VerticalAlignment="Top"
                            Background="{ThemeResource LiquidGlassSpecularBrush}"
                            CornerRadius="5"
                            IsHitTestVisible="False"
                            Opacity="0.18" />
                        <Border
                            Margin="1"
                            BorderBrush="{ThemeResource LiquidGlassEdgeGlowBrush}"
                            BorderThickness="1"
                            CornerRadius="15"
                            IsHitTestVisible="False"
                            Opacity="0.34" />
                        <Border
                            Margin="2"
                            Background="{ThemeResource LiquidGlassCausticBrush}"
                            CornerRadius="14"
                            IsHitTestVisible="False"
                            Opacity="0.06" />
                    </Grid>
                </Border>
                <Border
                    Margin="10,7,0,7"
                    Padding="8,0,11,0"
                    HorizontalAlignment="Left"
                    Background="{ThemeResource LiquidGlassToolbarBrush}"
                    BorderBrush="{ThemeResource LiquidGlassRimBrush}"
                    BorderThickness="1"
                    CornerRadius="15"
                    Loaded="BackdropDistortion_Loaded"
                    Tag="TitleCapsule"
                    Unloaded="BackdropDistortion_Unloaded"
                    IsHitTestVisible="False">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border
                            Grid.ColumnSpan="2"
                            Background="{ThemeResource LiquidGlassRefractionBrush}"
                            CornerRadius="14"
                            IsHitTestVisible="False"
                            Opacity="0.18" />
                        <Border
                            Grid.ColumnSpan="2"
                            Background="{ThemeResource LiquidGlassSpecularBrush}"
                            CornerRadius="14"
                            IsHitTestVisible="False"
                            Opacity="0.21" />
                        <Border
                            Grid.ColumnSpan="2"
                            Height="9"
                            Margin="11,2,11,0"
                            VerticalAlignment="Top"
                            Background="{ThemeResource LiquidGlassSpecularBrush}"
                            CornerRadius="5"
                            IsHitTestVisible="False"
                            Opacity="0.18" />
                        <Border
                            Grid.ColumnSpan="2"
                            Margin="1"
                            BorderBrush="{ThemeResource LiquidGlassEdgeGlowBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            IsHitTestVisible="False"
                            Opacity="0.36" />
                        <Image
                            Width="16"
                            Height="16"
                            VerticalAlignment="Center"
                            Source="Assets/AppIcon.ico" />
                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource LiquidGlassTextPrimaryBrush}"
                            Text="TodoDesk" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!--
            The Frame hosts pages for your application content. Add your UI to
            MainPage.xaml rather than here so you can use Page features such as
            navigation events and the Loaded lifecycle.
        -->
        <Frame x:Name="RootFrame" Grid.Row="1" />
    </Grid>
</Window>
