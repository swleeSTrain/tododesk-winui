<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="TodoApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TodoApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="TodoDesk"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootLayout" Background="{ThemeResource LiquidGlassWindowBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.RowSpan="2"
            Background="{ThemeResource LiquidGlassRegularWashBrush}"
            IsHitTestVisible="False" />

        <Grid x:Name="CustomTitleBarHost" Height="36">
            <Border
                Background="{ThemeResource LiquidGlassRegularWashBrush}"
                Opacity="0.16" />
            <Border
                Background="{ThemeResource LiquidGlassContentInfusionBrush}"
                IsHitTestVisible="False"
                Opacity="0.055">
                <Border.RenderTransform>
                    <CompositeTransform ScaleX="1.18" SkewX="-8" />
                </Border.RenderTransform>
            </Border>
            <Border
                Background="{ThemeResource LiquidGlassSpecularBrush}"
                IsHitTestVisible="False"
                Opacity="0.040" />
            <Border
                Height="5"
                Margin="72,3,190,0"
                VerticalAlignment="Top"
                Background="{ThemeResource LiquidGlassSpecularBrush}"
                CornerRadius="2"
                IsHitTestVisible="False"
                Opacity="0.055" />
            <Border
                Height="6"
                Margin="360,1,280,0"
                VerticalAlignment="Center"
                Background="{ThemeResource LiquidGlassCausticBrush}"
                CornerRadius="2"
                IsHitTestVisible="False"
                Opacity="0.026" />
            <Border
                Height="1"
                VerticalAlignment="Bottom"
                Background="{ThemeResource LiquidGlassEdgeGlowBrush}"
                IsHitTestVisible="False"
                Opacity="0.16" />
            <Border
                Height="1"
                Margin="0,0,0,1"
                VerticalAlignment="Bottom"
                Background="{ThemeResource LiquidGlassShadowStrokeBrush}"
                IsHitTestVisible="False"
                Opacity="0.08" />
            <Grid
                x:Name="AppTitleBar"
                Background="Transparent">
                <Grid x:Name="LiquidTitleBarLayer">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Grid.Column="2"
                        Margin="4,5,10,5"
                        Background="{ThemeResource LiquidGlassToolbarBrush}"
                        BorderBrush="{ThemeResource LiquidGlassRimBrush}"
                        BorderThickness="1"
                        CornerRadius="3"
                        IsHitTestVisible="False"
                        Loaded="BackdropDistortion_Loaded"
                        Tag="TitleCapsule"
                        Unloaded="BackdropDistortion_Unloaded">
                        <Grid>
                            <Border
                                Background="{ThemeResource LiquidGlassRefractionBrush}"
                                CornerRadius="2"
                                IsHitTestVisible="False"
                                Opacity="0.18" />
                            <Border
                                Background="{ThemeResource LiquidGlassSpecularBrush}"
                                CornerRadius="2"
                                IsHitTestVisible="False"
                                Opacity="0.20" />
                            <Border
                                Height="4"
                                Margin="14,2,14,0"
                                VerticalAlignment="Top"
                                Background="{ThemeResource LiquidGlassSpecularBrush}"
                                CornerRadius="2"
                                IsHitTestVisible="False"
                                Opacity="0.18" />
                            <Border
                                Margin="1"
                                BorderBrush="{ThemeResource LiquidGlassEdgeGlowBrush}"
                                BorderThickness="1"
                                CornerRadius="2"
                                IsHitTestVisible="False"
                                Opacity="0.34" />
                            <Border
                                Margin="2"
                                Background="{ThemeResource LiquidGlassCausticBrush}"
                                CornerRadius="2"
                                IsHitTestVisible="False"
                                Opacity="0.06" />
                        </Grid>
                    </Border>
                    <Border
                        Margin="10,5,0,5"
                        Padding="8,0,11,0"
                        HorizontalAlignment="Left"
                        Background="{ThemeResource LiquidGlassToolbarBrush}"
                        BorderBrush="{ThemeResource LiquidGlassRimBrush}"
                        BorderThickness="1"
                        CornerRadius="3"
                        IsHitTestVisible="False"
                        Loaded="BackdropDistortion_Loaded"
                        Tag="TitleCapsule"
                        Unloaded="BackdropDistortion_Unloaded">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border
                                Grid.ColumnSpan="2"
                                Background="{ThemeResource LiquidGlassRefractionBrush}"
                                CornerRadius="2"
                                IsHitTestVisible="False"
                                Opacity="0.18" />
                            <Border
                                Grid.ColumnSpan="2"
                                Background="{ThemeResource LiquidGlassSpecularBrush}"
                                CornerRadius="2"
                                IsHitTestVisible="False"
                                Opacity="0.21" />
                            <Border
                                Grid.ColumnSpan="2"
                                Height="4"
                                Margin="11,2,11,0"
                                VerticalAlignment="Top"
                                Background="{ThemeResource LiquidGlassSpecularBrush}"
                                CornerRadius="2"
                                IsHitTestVisible="False"
                                Opacity="0.18" />
                            <Border
                                Grid.ColumnSpan="2"
                                Margin="1"
                                BorderBrush="{ThemeResource LiquidGlassEdgeGlowBrush}"
                                BorderThickness="1"
                                CornerRadius="2"
                                IsHitTestVisible="False"
                                Opacity="0.36" />
                            <Image
                                Width="16"
                                Height="16"
                                VerticalAlignment="Center"
                                Source="Assets/AppIcon.ico" />
                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource LiquidGlassTextPrimaryBrush}"
                                Text="TodoDesk" />
                        </Grid>
                    </Border>
                </Grid>

                <Grid
                    x:Name="XpTitleBarLayer"
                    IsHitTestVisible="False"
                    Visibility="Collapsed">
                    <Border Background="{ThemeResource LiquidGlassWindowBrush}" />
                    <Border
                        Height="1"
                        VerticalAlignment="Top"
                        Background="#FF7BA9E5" />
                    <Border
                        Height="1"
                        VerticalAlignment="Bottom"
                        Background="#FF0A246A" />
                    <Grid Margin="6,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="138" />
                        </Grid.ColumnDefinitions>
                        <Image
                            Width="16"
                            Height="16"
                            VerticalAlignment="Center"
                            Source="Assets/AppIcon.ico" />
                        <TextBlock
                            Grid.Column="1"
                            Margin="6,0,0,1"
                            VerticalAlignment="Center"
                            FontFamily="Segoe UI"
                            FontSize="13"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="TodoDesk" />
                        <Grid
                            Grid.Column="2"
                            Margin="0,4,0,4"
                            HorizontalAlignment="Right">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="46" />
                                <ColumnDefinition Width="46" />
                                <ColumnDefinition Width="46" />
                            </Grid.ColumnDefinitions>
                            <Border
                                Width="22"
                                HorizontalAlignment="Center"
                                BorderBrush="#FF0A246A"
                                BorderThickness="1"
                                CornerRadius="3">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#FFFFFFFF" Offset="0" />
                                        <GradientStop Color="#FF7BB6FF" Offset="0.18" />
                                        <GradientStop Color="#FF1D63D8" Offset="0.58" />
                                        <GradientStop Color="#FF0640A5" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <Border
                                Grid.Column="1"
                                Width="22"
                                HorizontalAlignment="Center"
                                BorderBrush="#FF0A246A"
                                BorderThickness="1"
                                CornerRadius="3">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#FFFFFFFF" Offset="0" />
                                        <GradientStop Color="#FF7BB6FF" Offset="0.18" />
                                        <GradientStop Color="#FF1D63D8" Offset="0.58" />
                                        <GradientStop Color="#FF0640A5" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <Border
                                Grid.Column="2"
                                Width="22"
                                HorizontalAlignment="Center"
                                BorderBrush="#FF6A1B00"
                                BorderThickness="1"
                                CornerRadius="3">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#FFFFD7C6" Offset="0" />
                                        <GradientStop Color="#FFFF8D6B" Offset="0.22" />
                                        <GradientStop Color="#FFE13B16" Offset="0.62" />
                                        <GradientStop Color="#FFA51B00" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <!--
            The Frame hosts pages for your application content. Add your UI to
            MainPage.xaml rather than here so you can use Page features such as
            navigation events and the Loaded lifecycle.
        -->
        <Frame x:Name="RootFrame" Grid.Row="1" />
    </Grid>
</Window>
