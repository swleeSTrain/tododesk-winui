<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TodoApp.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TodoApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    Loaded="Page_Loaded"
    mc:Ignorable="d">

    <Grid Background="Transparent">
    <Grid x:Name="CustomThemeRoot" Background="Transparent">
        <Grid.Resources>
        <Style x:Key="MutedCaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{ThemeResource LiquidGlassTextSecondaryBrush}" />
        </Style>

        <Style x:Key="QuietMetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <ThemeShadow x:Key="LiquidGlassPanelShadow" />
        <ThemeShadow x:Key="LiquidGlassCardShadow" />

        <StaticResource x:Key="TextControlBackground" ResourceKey="LiquidGlassToolbarBrush" />
        <StaticResource x:Key="TextControlBackgroundPointerOver" ResourceKey="LiquidGlassHoverBrush" />
        <StaticResource x:Key="TextControlBackgroundFocused" ResourceKey="LiquidGlassControlCheckedBrush" />
        <StaticResource x:Key="TextControlBorderBrush" ResourceKey="LiquidGlassRimBrush" />
        <StaticResource x:Key="TextControlBorderBrushPointerOver" ResourceKey="LiquidGlassEdgeGlowBrush" />
        <StaticResource x:Key="TextControlBorderBrushFocused" ResourceKey="LiquidGlassEdgeGlowBrush" />
        <StaticResource x:Key="TextControlForeground" ResourceKey="LiquidGlassTextPrimaryBrush" />
        <StaticResource x:Key="TextControlForegroundPointerOver" ResourceKey="LiquidGlassTextPrimaryBrush" />
        <StaticResource x:Key="TextControlForegroundFocused" ResourceKey="LiquidGlassTextPrimaryBrush" />
        <StaticResource x:Key="TextControlPlaceholderForeground" ResourceKey="LiquidGlassTextSecondaryBrush" />
        <StaticResource x:Key="TextControlPlaceholderForegroundPointerOver" ResourceKey="LiquidGlassTextSecondaryBrush" />
        <StaticResource x:Key="TextControlPlaceholderForegroundFocused" ResourceKey="LiquidGlassTextSecondaryBrush" />
        <StaticResource x:Key="TextControlHeaderForeground" ResourceKey="LiquidGlassTextSecondaryBrush" />
        <StaticResource x:Key="TextControlHeaderForegroundFocused" ResourceKey="LiquidGlassTextPrimaryBrush" />
        <Thickness x:Key="TextControlBorderThemeThicknessFocused">1</Thickness>
        <StaticResource x:Key="TextControlCornerRadius" ResourceKey="LiquidGlassControlCornerRadius" />

        <StaticResource x:Key="ButtonBackground" ResourceKey="LiquidGlassToolbarBrush" />
        <StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="LiquidGlassHoverBrush" />
        <StaticResource x:Key="ButtonBackgroundPressed" ResourceKey="LiquidGlassSelectedBrush" />
        <StaticResource x:Key="ButtonBackgroundDisabled" ResourceKey="LiquidGlassRowBrush" />
        <StaticResource x:Key="ButtonForeground" ResourceKey="LiquidGlassTextPrimaryBrush" />
        <StaticResource x:Key="ButtonForegroundPointerOver" ResourceKey="LiquidGlassTextPrimaryBrush" />
        <StaticResource x:Key="ButtonForegroundPressed" ResourceKey="LiquidGlassTextPrimaryBrush" />
        <StaticResource x:Key="ButtonForegroundDisabled" ResourceKey="LiquidGlassTextSecondaryBrush" />
        <StaticResource x:Key="ButtonBorderBrush" ResourceKey="LiquidGlassRimBrush" />
        <StaticResource x:Key="ButtonBorderBrushPointerOver" ResourceKey="LiquidGlassEdgeGlowBrush" />
        <StaticResource x:Key="ButtonBorderBrushPressed" ResourceKey="LiquidGlassAccentBrush" />
        <StaticResource x:Key="ButtonBorderBrushDisabled" ResourceKey="LiquidGlassRimBrush" />
        <Thickness x:Key="ButtonBorderThemeThickness">1</Thickness>
        <StaticResource x:Key="DropDownButtonForegroundSecondary" ResourceKey="LiquidGlassTextSecondaryBrush" />
        <StaticResource x:Key="DropDownButtonForegroundSecondaryPointerOver" ResourceKey="LiquidGlassTextPrimaryBrush" />
        <StaticResource x:Key="DropDownButtonForegroundSecondaryPressed" ResourceKey="LiquidGlassAccentBrush" />

        <StaticResource x:Key="ComboBoxBackground" ResourceKey="LiquidGlassToolbarBrush" />
        <StaticResource x:Key="ComboBoxBackgroundPointerOver" ResourceKey="LiquidGlassHoverBrush" />
        <StaticResource x:Key="ComboBoxBackgroundPressed" ResourceKey="LiquidGlassSelectedBrush" />
        <StaticResource x:Key="ComboBoxBackgroundFocused" ResourceKey="LiquidGlassControlCheckedBrush" />
        <StaticResource x:Key="ComboBoxBackgroundUnfocused" ResourceKey="LiquidGlassToolbarBrush" />
        <StaticResource x:Key="ComboBoxBorderBrush" ResourceKey="LiquidGlassRimBrush" />
        <StaticResource x:Key="ComboBoxBorderBrushPointerOver" ResourceKey="LiquidGlassEdgeGlowBrush" />
        <StaticResource x:Key="ComboBoxBorderBrushPressed" ResourceKey="LiquidGlassAccentBrush" />
        <StaticResource x:Key="ComboBoxBackgroundBorderBrushFocused" ResourceKey="LiquidGlassAccentBrush" />
        <StaticResource x:Key="ComboBoxBackgroundBorderBrushUnfocused" ResourceKey="LiquidGlassRimBrush" />
        <StaticResource x:Key="ComboBoxDropDownBackground" ResourceKey="LiquidGlassDropDownBrush" />
        <StaticResource x:Key="ComboBoxDropDownForeground" ResourceKey="LiquidGlassTextPrimaryBrush" />
        <StaticResource x:Key="ComboBoxDropDownBorderBrush" ResourceKey="LiquidGlassEdgeGlowBrush" />
        <StaticResource x:Key="ComboBoxDropDownBackgroundPointerOver" ResourceKey="LiquidGlassHoverBrush" />
        <StaticResource x:Key="ComboBoxDropDownBackgroundPointerPressed" ResourceKey="LiquidGlassSelectedBrush" />
        <StaticResource x:Key="ComboBoxFocusedDropDownBackgroundPointerOver" ResourceKey="LiquidGlassHoverBrush" />
        <StaticResource x:Key="ComboBoxFocusedDropDownBackgroundPointerPressed" ResourceKey="LiquidGlassSelectedBrush" />
        <SolidColorBrush x:Key="ComboBoxItemBackground" Color="Transparent" />
        <StaticResource x:Key="ComboBoxItemBackgroundPointerOver" ResourceKey="LiquidGlassHoverBrush" />
        <StaticResource x:Key="ComboBoxItemBackgroundPressed" ResourceKey="LiquidGlassSelectedBrush" />
        <StaticResource x:Key="ComboBoxItemBackgroundSelected" ResourceKey="LiquidGlassControlCheckedBrush" />
        <StaticResource x:Key="ComboBoxItemBackgroundSelectedPointerOver" ResourceKey="LiquidGlassHoverBrush" />
        <StaticResource x:Key="ComboBoxItemBackgroundSelectedPressed" ResourceKey="LiquidGlassSelectedBrush" />
        <SolidColorBrush x:Key="ComboBoxItemRevealBackground" Color="Transparent" />
        <StaticResource x:Key="ComboBoxItemRevealBackgroundPointerOver" ResourceKey="LiquidGlassHoverBrush" />
        <StaticResource x:Key="ComboBoxItemRevealBackgroundPressed" ResourceKey="LiquidGlassSelectedBrush" />
        <StaticResource x:Key="ComboBoxItemRevealBackgroundSelected" ResourceKey="LiquidGlassControlCheckedBrush" />
        <StaticResource x:Key="ComboBoxItemRevealBackgroundSelectedPointerOver" ResourceKey="LiquidGlassHoverBrush" />
        <StaticResource x:Key="ComboBoxItemRevealBackgroundSelectedPressed" ResourceKey="LiquidGlassSelectedBrush" />
        <Thickness x:Key="ComboBoxDropdownBorderThickness">1</Thickness>
        <Thickness x:Key="ComboBoxDropdownBorderPadding">2</Thickness>
        <Thickness x:Key="ComboBoxDropdownContentMargin">6,8</Thickness>
        <StaticResource x:Key="OverlayCornerRadius" ResourceKey="LiquidGlassOverlayCornerRadius" />
        <StaticResource x:Key="ComboBoxCornerRadius" ResourceKey="LiquidGlassControlCornerRadius" />
        <StaticResource x:Key="ComboBoxDropDownButtonBackgroundCornerRadius" ResourceKey="LiquidGlassControlCornerRadius" />
        <StaticResource x:Key="ComboBoxHiglightBorderCornerRadius" ResourceKey="LiquidGlassControlCornerRadius" />
        <StaticResource x:Key="ComboBoxItemCornerRadius" ResourceKey="LiquidGlassControlCornerRadius" />
        <StaticResource x:Key="ComboBoxItemPillCornerRadius" ResourceKey="LiquidGlassControlCornerRadius" />

        <Thickness x:Key="NavigationViewItemButtonMargin">8,3</Thickness>
        <x:Double x:Key="NavigationViewItemOnLeftMinHeight">40</x:Double>
        <x:Double x:Key="NavigationViewSelectionIndicatorWidth">2</x:Double>
        <x:Double x:Key="NavigationViewSelectionIndicatorHeight">18</x:Double>
        <x:Double x:Key="NavigationViewSelectionIndicatorRadius">2</x:Double>
        <StaticResource x:Key="ListViewItemCornerRadius" ResourceKey="LiquidGlassControlCornerRadius" />
        <x:Boolean x:Key="ListViewItemSelectionIndicatorVisualEnabled">False</x:Boolean>
        <x:Double x:Key="ListViewItemSelectedBorderThemeThickness">0</x:Double>
        <CornerRadius x:Key="ListViewItemSelectionIndicatorCornerRadius">3</CornerRadius>

        <Style x:Key="LiquidGlassPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource ContentMaterialSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource ContentMaterialStrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{ThemeResource LiquidGlassPanelCornerRadius}" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="Shadow" Value="{StaticResource LiquidGlassPanelShadow}" />
        </Style>

        <Style x:Key="ContentMaterialInnerHighlightStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{ThemeResource ContentMaterialStrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{ThemeResource LiquidGlassPanelCornerRadius}" />
            <Setter Property="Opacity" Value="0.42" />
        </Style>

        <Style x:Key="LiquidGlassInnerHighlightStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{ThemeResource LiquidGlassEdgeGlowBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{ThemeResource LiquidGlassPanelCornerRadius}" />
            <Setter Property="Opacity" Value="0.72" />
        </Style>

        <Style x:Key="LiquidGlassCardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{ThemeResource ContentMaterialRowBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource ContentMaterialStrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{ThemeResource LiquidGlassCardCornerRadius}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="Shadow" Value="{StaticResource LiquidGlassCardShadow}" />
        </Style>

        <Style x:Key="LiquidGlassBoardLaneStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource ContentMaterialSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource ContentMaterialStrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{ThemeResource LiquidGlassLaneCornerRadius}" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="Shadow" Value="{StaticResource LiquidGlassPanelShadow}" />
        </Style>

        <Style x:Key="LiquidGlassBoardHeaderStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource ContentMaterialRowBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource ContentMaterialStrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{ThemeResource LiquidGlassHeaderCornerRadius}" />
            <Setter Property="Padding" Value="10,7" />
        </Style>

        <Style x:Key="LiquidGlassActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{ThemeResource LiquidGlassToolbarBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource LiquidGlassRimBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{ThemeResource LiquidGlassTextPrimaryBrush}" />
            <Setter Property="CornerRadius" Value="{ThemeResource LiquidGlassButtonCornerRadius}" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="RootBorder"
                            MinWidth="{TemplateBinding MinWidth}"
                            MinHeight="{TemplateBinding MinHeight}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource LiquidGlassHoverBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="BorderBrush">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource LiquidGlassEdgeGlowBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <DoubleAnimation
                                                Storyboard.TargetName="ButtonSpecularLayer"
                                                Storyboard.TargetProperty="Opacity"
                                                To="0.28"
                                                Duration="0:0:0.12" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource LiquidGlassSelectedBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="BorderBrush">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource LiquidGlassEdgeGlowBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <DoubleAnimation
                                                Storyboard.TargetName="ButtonSpecularLayer"
                                                Storyboard.TargetProperty="Opacity"
                                                To="0.18"
                                                Duration="0:0:0.05" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="RootBorder"
                                                Storyboard.TargetProperty="Opacity"
                                                To="0.48"
                                                Duration="0" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Grid Padding="{TemplateBinding Padding}">
                                <Border
                                    x:Name="ButtonSpecularLayer"
                                    Background="{ThemeResource LiquidGlassSpecularBrush}"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    IsHitTestVisible="False"
                                    Opacity="0.20" />
                                <Border
                                    Background="{ThemeResource LiquidGlassCausticBrush}"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    IsHitTestVisible="False"
                                    Opacity="0.075" />
                                <Border
                                    Height="12"
                                    Margin="8,1,8,0"
                                    VerticalAlignment="Top"
                                    Background="{ThemeResource LiquidGlassSpecularBrush}"
                                    CornerRadius="3"
                                    IsHitTestVisible="False"
                                    Opacity="0.16" />
                                <Border
                                    BorderBrush="{ThemeResource LiquidGlassEdgeGlowBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    IsHitTestVisible="False"
                                    Opacity="0.30" />
                                <ContentPresenter
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    Content="{TemplateBinding Content}" />
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LiquidGlassToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource LiquidGlassActionButtonStyle}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
            <Setter Property="FocusVisualPrimaryBrush" Value="{ThemeResource LiquidGlassEdgeGlowBrush}" />
            <Setter Property="FocusVisualSecondaryBrush" Value="{ThemeResource LiquidGlassStrokeBrush}" />
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="36" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>

        <Style x:Key="LiquidGlassControlGroupStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource LiquidGlassToolbarBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource LiquidGlassRimBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Shadow" Value="{StaticResource LiquidGlassCardShadow}" />
        </Style>

        <Style x:Key="LiquidGlassToolbarToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="36" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
            <Setter Property="FocusVisualPrimaryBrush" Value="{ThemeResource LiquidGlassEdgeGlowBrush}" />
            <Setter Property="FocusVisualSecondaryBrush" Value="{ThemeResource LiquidGlassStrokeBrush}" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border
                            x:Name="RootBorder"
                            MinWidth="{TemplateBinding MinWidth}"
                            MinHeight="{TemplateBinding MinHeight}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource LiquidGlassHoverBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="BorderBrush">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource LiquidGlassStrokeBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource LiquidGlassSelectedBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="BorderBrush">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource LiquidGlassEdgeGlowBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled" />
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="CheckStates">
                                    <VisualState x:Name="Checked">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource LiquidGlassControlCheckedBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="BorderBrush">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource LiquidGlassEdgeGlowBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Unchecked" />
                                    <VisualState x:Name="Indeterminate">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource LiquidGlassControlCheckedBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Grid>
                                <Border
                                    Background="{ThemeResource LiquidGlassSpecularBrush}"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    IsHitTestVisible="False"
                                    Opacity="0.10" />
                                <Border
                                    Background="{ThemeResource LiquidGlassCausticBrush}"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    IsHitTestVisible="False"
                                    Opacity="0.045" />
                                <Border
                                    BorderBrush="{ThemeResource LiquidGlassEdgeGlowBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    IsHitTestVisible="False"
                                    Opacity="0.20" />
                                <ContentPresenter
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    Content="{TemplateBinding Content}" />
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LiquidGlassTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{ThemeResource LiquidGlassToolbarBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource LiquidGlassRimBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{ThemeResource LiquidGlassTextPrimaryBrush}" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        </Style>

        <Style x:Key="LiquidGlassDropDownButtonStyle" TargetType="DropDownButton">
            <Setter Property="Background" Value="{ThemeResource LiquidGlassToolbarBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource LiquidGlassRimBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="13,7" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
            <Setter Property="FocusVisualPrimaryBrush" Value="{ThemeResource LiquidGlassEdgeGlowBrush}" />
            <Setter Property="FocusVisualSecondaryBrush" Value="{ThemeResource LiquidGlassStrokeBrush}" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DropDownButton">
                        <Border
                            x:Name="RootBorder"
                            MinWidth="{TemplateBinding MinWidth}"
                            MinHeight="{TemplateBinding MinHeight}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource LiquidGlassHoverBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="BorderBrush">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource LiquidGlassEdgeGlowBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <DoubleAnimation
                                                Storyboard.TargetName="DropDownSpecularLayer"
                                                Storyboard.TargetProperty="Opacity"
                                                To="0.30"
                                                Duration="0:0:0.12" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource LiquidGlassSelectedBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="BorderBrush">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource LiquidGlassEdgeGlowBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="RootBorder"
                                                Storyboard.TargetProperty="Opacity"
                                                To="0.48"
                                                Duration="0" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="FocusStates">
                                    <VisualState x:Name="Focused">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="BorderBrush">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource LiquidGlassEdgeGlowBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <DoubleAnimation
                                                Storyboard.TargetName="DropDownFocusHalo"
                                                Storyboard.TargetProperty="Opacity"
                                                To="0.42"
                                                Duration="0:0:0.12" />
                                            <DoubleAnimation
                                                Storyboard.TargetName="DropDownSpecularLayer"
                                                Storyboard.TargetProperty="Opacity"
                                                To="0.28"
                                                Duration="0:0:0.12" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Unfocused" />
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Grid Padding="{TemplateBinding Padding}" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border
                                    x:Name="DropDownSpecularLayer"
                                    Grid.ColumnSpan="2"
                                    Background="{ThemeResource LiquidGlassSpecularBrush}"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    IsHitTestVisible="False"
                                    Opacity="0.19" />
                                <Border
                                    Grid.ColumnSpan="2"
                                    Background="{ThemeResource LiquidGlassCausticBrush}"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    IsHitTestVisible="False"
                                    Opacity="0.070" />
                                <Border
                                    Grid.ColumnSpan="2"
                                    Height="12"
                                    Margin="8,0,8,0"
                                    VerticalAlignment="Top"
                                    Background="{ThemeResource LiquidGlassSpecularBrush}"
                                    CornerRadius="3"
                                    IsHitTestVisible="False"
