                    x:Name="FluentThemeComboBox"
                    Grid.Column="6"
                    MinWidth="145"
                    AutomationProperties.AutomationId="FluentThemeComboBox"
                    SelectionChanged="FluentThemeComboBox_SelectionChanged">
                    <ComboBoxItem Content="WinUI Fluent" Tag="fluent" />
                    <ComboBoxItem Content="Liquid Glass" Tag="liquid" />
                    <ComboBoxItem Content="Windows XP" Tag="xp" />
                    <ComboBoxItem Content="Aero" Tag="aero" />
                </ComboBox>
            </Grid>

            <Grid Grid.Row="2" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="360" />
                </Grid.ColumnDefinitions>

                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Padding="12,0" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="92" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Opacity="0.72" Text="KEY" />
                        <TextBlock Grid.Column="1" Opacity="0.72" Text="ISSUE" />
                        <TextBlock Grid.Column="2" Opacity="0.72" Text="STATUS" />
                        <TextBlock Grid.Column="3" Opacity="0.72" Text="OWNER" />
                        <TextBlock Grid.Column="4" Opacity="0.72" Text="DUE" />
                    </Grid>

                    <ListView
                        x:Name="FluentIssueListView"
                        Grid.Row="1"
                        AutomationProperties.AutomationId="FluentIssueListView"
                        ItemsSource="{x:Bind VisibleIssues, Mode=OneWay}"
                        SelectionChanged="FluentIssueListView_SelectionChanged"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:IssueItem">
                                <Grid MinHeight="56" Padding="12,8" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="100" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Text="{x:Bind Key, Mode=OneWay}" />
                                    <Grid Grid.Column="1" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Ellipse
                                            Width="8"
                                            Height="8"
                                            VerticalAlignment="Center"
                                            Fill="{x:Bind StatusBrush, Mode=OneWay}" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Title, Mode=OneWay}" />
                                            <TextBlock
                                                Opacity="0.72"
                                                Text="{x:Bind RowSubtitle, Mode=OneWay}" />
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        Text="{x:Bind StatusLabel, Mode=OneWay}" />
                                    <TextBlock
                                        Grid.Column="3"
                                        VerticalAlignment="Center"
                                        Text="{x:Bind Assignee, Mode=OneWay}" />
                                    <TextBlock
                                        Grid.Column="4"
                                        VerticalAlignment="Center"
                                        Text="{x:Bind DueDate, Mode=OneWay}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel
                        x:Name="FluentEmptyState"
                        Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8"
                        Visibility="Collapsed">
                        <FontIcon Glyph="&#xE8FD;" />
                        <TextBlock Text="조건에 맞는 이슈가 없습니다." />
                    </StackPanel>
                </Grid>

                <Grid Grid.Column="1">
                    <StackPanel
                        x:Name="FluentDetailEmptyState"
                        VerticalAlignment="Center"
                        Spacing="8">
                        <TextBlock
                            FontSize="20"
                            FontWeight="SemiBold"
                            Text="이슈 선택" />
                        <TextBlock
                            Opacity="0.72"
                            Text="왼쪽 리스트에서 이슈를 선택하세요."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <ScrollViewer
                        x:Name="FluentDetailEditor"
                        Visibility="Collapsed">
                        <StackPanel Spacing="10">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    x:Name="FluentSelectedKeyTextBlock"
                                    VerticalAlignment="Center"
                                    Opacity="0.72" />
                                <TextBlock
                                    x:Name="FluentSelectedStatusTextBlock"
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            </Grid>

                            <TextBox
                                x:Name="FluentIssueTitleTextBox"
                                AutomationProperties.AutomationId="FluentIssueTitleTextBox"
                                Header="제목" />
                            <TextBox
                                x:Name="FluentIssueDescriptionTextBox"
                                AcceptsReturn="True"
                                AutomationProperties.AutomationId="FluentIssueDescriptionTextBox"
                                Header="설명"
                                Height="104"
                                TextWrapping="Wrap" />

                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ComboBox
                                    x:Name="FluentDetailStatusComboBox"
                                    AutomationProperties.AutomationId="FluentDetailStatusComboBox"
                                    Header="상태"
                                    HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="백로그" Tag="Backlog" />
                                    <ComboBoxItem Content="예정" Tag="Todo" />
                                    <ComboBoxItem Content="진행 중" Tag="InProgress" />
                                    <ComboBoxItem Content="리뷰" Tag="Review" />
                                    <ComboBoxItem Content="완료" Tag="Done" />
                                </ComboBox>
                                <ComboBox
                                    x:Name="FluentDetailPriorityComboBox"
                                    Grid.Column="1"
                                    AutomationProperties.AutomationId="FluentDetailPriorityComboBox"
                                    Header="우선순위"
                                    HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="긴급" Tag="Urgent" />
                                    <ComboBoxItem Content="높음" Tag="High" />
                                    <ComboBoxItem Content="보통" Tag="Medium" />
                                    <ComboBoxItem Content="낮음" Tag="Low" />
                                </ComboBox>
                            </Grid>

                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ComboBox
                                    x:Name="FluentDetailProjectComboBox"
                                    AutomationProperties.AutomationId="FluentDetailProjectComboBox"
                                    Header="프로젝트"
                                    HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="Platform" Tag="Platform" />
                                    <ComboBoxItem Content="Mobile" Tag="Mobile" />
                                    <ComboBoxItem Content="Growth" Tag="Growth" />
                                    <ComboBoxItem Content="Ops" Tag="Ops" />
                                </ComboBox>
                                <ComboBox
                                    x:Name="FluentDetailAssigneeComboBox"
                                    Grid.Column="1"
                                    AutomationProperties.AutomationId="FluentDetailAssigneeComboBox"
                                    Header="담당자"
                                    HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="나" Tag="나" />
                                    <ComboBoxItem Content="Design" Tag="Design" />
                                    <ComboBoxItem Content="Backend" Tag="Backend" />
                                    <ComboBoxItem Content="QA" Tag="QA" />
                                </ComboBox>
                            </Grid>

                            <TextBox
                                x:Name="FluentIssueDueDateTextBox"
                                AutomationProperties.AutomationId="FluentIssueDueDateTextBox"
                                Header="기한" />
                            <TextBox
                                x:Name="FluentIssueLabelsTextBox"
                                AutomationProperties.AutomationId="FluentIssueLabelsTextBox"
                                Header="라벨" />

                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    x:Name="FluentDetailHintTextBlock"
                                    VerticalAlignment="Center"
                                    Opacity="0.72" />
                                <CommandBar
                                    Grid.Column="1"
                                    DefaultLabelPosition="Collapsed"
                                    IsOpen="False">
                                    <AppBarButton
                                        AutomationProperties.AutomationId="FluentSaveIssueButton"
                                        Icon="Save"
                                        Label="저장"
                                        Click="FluentSaveIssue_Click" />
                                    <AppBarButton
                                        AutomationProperties.AutomationId="FluentDeleteIssueButton"
                                        Icon="Delete"
                                        Label="삭제"
                                        Click="DeleteSelectedIssue_Click" />
                                </CommandBar>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </NavigationView>
    </Grid>
</Page>
